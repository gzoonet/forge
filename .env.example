# ── LLM Provider Configuration ──
# Set the provider and API key for the LLM you want to use.
# Only one provider needs to be configured.

# Provider: "anthropic" | "openai" | "openai-compatible"
FORGE_LLM_PROVIDER=anthropic

# ── Anthropic ──
ANTHROPIC_API_KEY=your-anthropic-key-here

# ── OpenAI ──
# FORGE_LLM_PROVIDER=openai
# OPENAI_API_KEY=your-openai-key-here

# ── OpenAI-compatible (Groq, Together, Ollama, etc.) ──
# FORGE_LLM_PROVIDER=openai-compatible
# OPENAI_API_KEY=your-api-key-here
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# FORGE_FAST_MODEL=llama-3.3-70b-versatile
# FORGE_QUALITY_MODEL=llama-3.3-70b-versatile

# ── Model overrides (optional, works with any provider) ──
# FORGE_FAST_MODEL overrides the "haiku" / fast classifier model
# FORGE_QUALITY_MODEL overrides the "sonnet" / quality extractor model
# FORGE_FAST_MODEL=claude-haiku-4-5-20251001
# FORGE_QUALITY_MODEL=claude-sonnet-4-6
